---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacto"
  lang="es"
  description="Contacta con la Cátedra DACSA-UV. Facultad de Economía, Universitat de Valencia. Teléfono, email y ubicación."
>

  <!-- ====================================================
       SECTION 1 — PAGE HEADER
       ==================================================== -->
  <section class="bg-dacsa-dark text-white" aria-labelledby="contact-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <p class="text-dacsa-amber text-sm font-semibold tracking-widest uppercase mb-4">
        Cátedra DACSA · Universitat de Valencia
      </p>
      <h1 id="contact-heading" class="text-4xl sm:text-5xl font-bold mb-4">
        Contacto
      </h1>
      <p class="text-gray-300 text-lg leading-relaxed max-w-2xl">
        Estamos en la Facultad de Economía de la Universitat de Valencia. Puedes contactarnos
        por email o teléfono para cualquier consulta sobre la cátedra, el premio o las actividades.
      </p>
    </div>
  </section>

  <!-- ====================================================
       SECTION 2 — CONTACT DETAILS + MAP (two-column)
       ==================================================== -->
  <section class="bg-white" aria-labelledby="contact-details-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16">

        <!-- Left column: contact details -->
        <div>
          <h2 id="contact-details-heading" class="text-2xl font-bold text-dacsa-dark mb-8">
            Información de contacto
          </h2>

          <!-- Address -->
          <div class="mb-8">
            <h3 class="text-xs font-semibold uppercase tracking-widest text-dacsa-amber mb-3">
              Dirección
            </h3>
            <address class="not-italic text-sm text-dacsa-gray leading-relaxed space-y-1">
              <p class="font-medium text-dacsa-dark">Cátedra DACSA-UV</p>
              <p>Facultad de Economía, Despacho 5C04</p>
              <p>Avda. Tarongers, s/n</p>
              <p>46022 Valencia</p>
            </address>
          </div>

          <!-- Contact channels -->
          <div class="mb-8">
            <h3 class="text-xs font-semibold uppercase tracking-widest text-dacsa-amber mb-3">
              Canales de contacto
            </h3>
            <ul class="space-y-3 list-none text-sm" role="list">

              <li>
                <a
                  href="mailto:catedradacsa@uv.es"
                  class="flex items-center gap-3 text-dacsa-gray hover:text-dacsa-amber transition-colors group"
                  aria-label="Enviar email a catedradacsa@uv.es"
                >
                  <!-- Email icon -->
                  <span
                    class="w-9 h-9 flex items-center justify-center bg-gray-50 border border-gray-200 rounded-sm group-hover:bg-amber-50 group-hover:border-dacsa-amber transition-colors shrink-0"
                    aria-hidden="true"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                    </svg>
                  </span>
                  catedradacsa@uv.es
                </a>
              </li>

              <li>
                <a
                  href="tel:+34963828369"
                  class="flex items-center gap-3 text-dacsa-gray hover:text-dacsa-amber transition-colors group"
                  aria-label="Llamar al +34 963 828 369"
                >
                  <!-- Phone icon -->
                  <span
                    class="w-9 h-9 flex items-center justify-center bg-gray-50 border border-gray-200 rounded-sm group-hover:bg-amber-50 group-hover:border-dacsa-amber transition-colors shrink-0"
                    aria-hidden="true"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                    </svg>
                  </span>
                  +34 963 828 369
                </a>
              </li>

              <li>
                <a
                  href="tel:+34933828652"
                  class="flex items-center gap-3 text-dacsa-gray hover:text-dacsa-amber transition-colors group"
                  aria-label="Llamar al +34 933 828 652"
                >
                  <span
                    class="w-9 h-9 flex items-center justify-center bg-gray-50 border border-gray-200 rounded-sm group-hover:bg-amber-50 group-hover:border-dacsa-amber transition-colors shrink-0"
                    aria-hidden="true"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                    </svg>
                  </span>
                  +34 933 828 652
                </a>
              </li>

            </ul>
          </div>

          <!-- Social links -->
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-widest text-dacsa-amber mb-3">
              Redes sociales
            </h3>
            <ul class="flex flex-col gap-3 list-none text-sm" role="list">

              <li>
                <a
                  href="https://www.facebook.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 text-dacsa-gray hover:text-dacsa-amber transition-colors group"
                  aria-label="Cátedra DACSA-UV en Facebook (abre en nueva pestaña)"
                >
                  <span
                    class="w-9 h-9 flex items-center justify-center bg-gray-50 border border-gray-200 rounded-sm group-hover:bg-amber-50 group-hover:border-dacsa-amber transition-colors shrink-0"
                    aria-hidden="true"
                  >
                    <!-- Facebook icon -->
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                  </span>
                  Facebook
                </a>
              </li>

              <li>
                <a
                  href="https://www.linkedin.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 text-dacsa-gray hover:text-dacsa-amber transition-colors group"
                  aria-label="Cátedra DACSA-UV en LinkedIn (abre en nueva pestaña)"
                >
                  <span
                    class="w-9 h-9 flex items-center justify-center bg-gray-50 border border-gray-200 rounded-sm group-hover:bg-amber-50 group-hover:border-dacsa-amber transition-colors shrink-0"
                    aria-hidden="true"
                  >
                    <!-- LinkedIn icon -->
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                  </span>
                  LinkedIn
                </a>
              </li>

            </ul>
          </div>
        </div>

        <!-- Right column: map placeholder -->
        <div>
          <h2 class="text-2xl font-bold text-dacsa-dark mb-8">
            Ubicación
          </h2>

          <!--
            Map placeholder: no iframe embed to avoid GDPR/consent complexity.
            Replace this block with an actual map embed if/when consent is handled.
          -->
          <div
            class="w-full aspect-video bg-gray-100 border border-gray-200 rounded-sm flex flex-col items-center justify-center gap-4 text-center p-8"
            role="img"
            aria-label="Mapa de ubicación: Facultad de Economía, Universitat de Valencia"
          >
            <div class="w-12 h-12 flex items-center justify-center bg-white rounded-full border border-gray-200" aria-hidden="true">
              <svg class="w-6 h-6 text-dacsa-amber" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-dacsa-dark text-sm">Facultad de Economía</p>
              <p class="text-sm text-dacsa-gray">Universitat de Valencia</p>
              <p class="text-xs text-dacsa-gray mt-1">Avda. Tarongers, s/n — 46022 Valencia</p>
            </div>
            <a
              href="https://maps.google.com/?q=Facultad+de+Economia+Universitat+de+Valencia"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-dacsa-amber hover:text-amber-600 transition-colors"
              aria-label="Ver en Google Maps (abre en nueva pestaña)"
            >
              Ver en Google Maps &rarr;
            </a>
          </div>

          <!-- Quick note below map -->
          <p class="text-xs text-dacsa-gray mt-4 leading-relaxed">
            Campus de Tarongers, accesible en metro (L3/L9, parada Tarongers) y autobús
            urbano. Parking disponible en el campus.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ====================================================
       SECTION 3 — SPONSOR ACKNOWLEDGMENT
       ==================================================== -->
  <section class="bg-gray-50 border-t border-gray-200" aria-label="Programa UVCátedres">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 text-center">
      <p class="text-sm text-dacsa-gray leading-relaxed">
        La Cátedra DACSA-UV forma parte del programa
        <a
          href="https://www.uv.es/uvweb/servei-investigacio/ca/estructura-investigacio/catedres-empresarials/catedres-empresarials-1285888077572.html"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold text-dacsa-dark hover:text-dacsa-amber transition-colors"
          aria-label="UVCátedres — Universitat de Valencia (abre en nueva pestaña)"
        >
          UVCátedres
        </a>
        de la Universitat de Valencia.
      </p>
    </div>
  </section>

</BaseLayout>
