---
import BaseLayout from '../../layouts/BaseLayout.astro';
import impact from '../../data/impact.json';
import funders from '../../data/funders.json';
---

<BaseLayout
  title="Transparencia"
  lang="es"
  description="Transparencia financiera de la Cátedra DACSA-UV: quién nos financia, el impacto generado y el destino de los fondos desde 2013."
>

  <!-- ====================================================
       SECTION 1 — PAGE HEADER
       ==================================================== -->
  <section class="bg-dacsa-dark text-white" aria-labelledby="transparency-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <p class="text-dacsa-amber text-sm font-semibold tracking-widest uppercase mb-4">
        Cátedra DACSA · Universitat de Valencia
      </p>
      <h1 id="transparency-heading" class="text-4xl sm:text-5xl font-bold mb-4">
        Transparencia
      </h1>
      <p class="text-gray-300 text-lg leading-relaxed max-w-2xl">
        En la Cátedra DACSA-UV creemos en la transparencia como principio. Aquí puedes ver
        quién nos financia, cuánto hemos hecho y cómo cada edición genera impacto real en
        el ecosistema emprendedor valenciano.
      </p>
    </div>
  </section>

  <!-- ====================================================
       SECTION 2 — IMPACT METRICS (6 metrics, 3+3)
       ==================================================== -->
  <section class="bg-gray-50 border-b border-gray-200" aria-labelledby="impact-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 id="impact-heading" class="text-2xl sm:text-3xl font-bold text-dacsa-dark mb-10 text-center">
        Impacto acumulado
      </h2>
      <dl class="grid grid-cols-2 md:grid-cols-3 gap-8 text-center">

        <div class="flex flex-col items-center gap-1">
          <dt class="text-sm text-dacsa-gray font-medium order-last mt-1">Ediciones</dt>
          <dd class="text-5xl font-bold text-dacsa-amber leading-none">{impact.editions}</dd>
        </div>

        <div class="flex flex-col items-center gap-1">
          <dt class="text-sm text-dacsa-gray font-medium order-last mt-1">Años de actividad</dt>
          <dd class="text-5xl font-bold text-dacsa-amber leading-none">{impact.years}</dd>
        </div>

        <div class="flex flex-col items-center gap-1">
          <dt class="text-sm text-dacsa-gray font-medium order-last mt-1">Estudiantes alcanzados</dt>
          <dd class="text-5xl font-bold text-dacsa-amber leading-none">+{impact.studentsReached}</dd>
        </div>

        <div class="flex flex-col items-center gap-1">
          <dt class="text-sm text-dacsa-gray font-medium order-last mt-1">Proyectos evaluados</dt>
          <dd class="text-5xl font-bold text-dacsa-amber leading-none">+{impact.projectsEvaluated}</dd>
        </div>

        <div class="flex flex-col items-center gap-1">
          <dt class="text-sm text-dacsa-gray font-medium order-last mt-1">Conferencias impartidas</dt>
          <dd class="text-5xl font-bold text-dacsa-amber leading-none">+{impact.lecturesHeld}</dd>
        </div>

        <div class="flex flex-col items-center gap-1">
          <dt class="text-sm text-dacsa-gray font-medium order-last mt-1">Socios y colaboradores</dt>
          <dd class="text-5xl font-bold text-dacsa-amber leading-none">{impact.partnersCount}+</dd>
        </div>

      </dl>
    </div>
  </section>

  <!-- ====================================================
       SECTION 3 — FUNDERS
       ==================================================== -->
  <section class="bg-white" aria-labelledby="funders-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 id="funders-heading" class="text-2xl sm:text-3xl font-bold text-dacsa-dark mb-10">
        Quién nos financia
      </h2>

      <ul class="grid grid-cols-1 md:grid-cols-3 gap-6 list-none" role="list">
        {funders.map((funder) => (
          <li class="border border-gray-100 rounded-sm p-6 flex flex-col gap-4 hover:border-dacsa-amber hover:shadow-md transition-all overflow-hidden relative">

            <!-- Logo or text placeholder -->
            <div class="h-14 flex items-center">
              {funder.logo ? (
                <img
                  src={funder.logo}
                  alt={funder.name}
                  width="120"
                  height="40"
                  loading="lazy"
                  class="max-h-10 object-contain"
                />
              ) : (
                <!-- Text placeholder: replace with official logo SVG when available -->
                <span class="inline-flex items-center font-semibold text-dacsa-dark text-sm tracking-tight border border-gray-200 rounded px-3 py-2">
                  {funder.name}
                </span>
              )}
            </div>

            <!-- Role badge -->
            <span class="inline-flex w-fit text-xs font-semibold px-2.5 py-1 rounded-full bg-amber-100 text-dacsa-amber">
              {funder.role}
            </span>

            <!-- Description -->
            <p class="text-sm text-dacsa-gray leading-relaxed flex-grow">
              {funder.description}
            </p>

            <!-- Link -->
            <a
              href={funder.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-semibold text-dacsa-amber hover:text-amber-600 transition-colors mt-auto"
              aria-label={`Visitar sitio web de ${funder.name} (abre en nueva pestaña)`}
            >
              Visitar sitio web &rarr;
            </a>

          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ====================================================
       SECTION 4 — FUND ALLOCATION
       ==================================================== -->
  <section class="bg-gray-50 border-y border-gray-200" aria-labelledby="funds-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 id="funds-heading" class="text-2xl sm:text-3xl font-bold text-dacsa-dark mb-10">
        ¿A qué se destinan los fondos?
      </h2>

      <ul class="grid grid-cols-1 md:grid-cols-3 gap-8 list-none" role="list">

        <!-- Premio al Plan de Viabilidad -->
        <li class="flex flex-col gap-4">
          <div
            class="w-12 h-12 flex items-center justify-center bg-amber-50 rounded-sm text-dacsa-amber"
            aria-hidden="true"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0" />
            </svg>
          </div>
          <div>
            <h3 class="text-base font-semibold text-dacsa-dark mb-2">Premio al Plan de Viabilidad</h3>
            <p class="text-sm text-dacsa-gray leading-relaxed">
              La partida principal se destina a los premios del concurso anual: dotación
              económica para los proyectos ganadores y organización de la ceremonia de entrega.
            </p>
          </div>
        </li>

        <!-- Formación y conferencias -->
        <li class="flex flex-col gap-4">
          <div
            class="w-12 h-12 flex items-center justify-center bg-blue-50 rounded-sm text-blue-600"
            aria-hidden="true"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.966 8.966 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <div>
            <h3 class="text-base font-semibold text-dacsa-dark mb-2">Formación y conferencias</h3>
            <p class="text-sm text-dacsa-gray leading-relaxed">
              Honorarios de ponentes, materiales formativos, organización de talleres y
              seminarios a lo largo del curso académico.
            </p>
          </div>
        </li>

        <!-- Coordinación y difusión -->
        <li class="flex flex-col gap-4">
          <div
            class="w-12 h-12 flex items-center justify-center bg-green-50 rounded-sm text-dacsa-green"
            aria-hidden="true"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 110-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 01-1.44-4.282m3.102.069a18.03 18.03 0 01-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 018.835 2.535M10.34 6.66a23.847 23.847 0 008.835-2.535m0 0A23.74 23.74 0 0018.795 3m.38 1.125a23.91 23.91 0 011.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 001.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 010 3.46" />
            </svg>
          </div>
          <div>
            <h3 class="text-base font-semibold text-dacsa-dark mb-2">Coordinación y difusión</h3>
            <p class="text-sm text-dacsa-gray leading-relaxed">
              Gestión de la cátedra, comunicación, materiales de difusión y actividades de
              networking con el ecosistema empresarial.
            </p>
          </div>
        </li>

      </ul>
    </div>
  </section>

  <!-- ====================================================
       SECTION 5 — ANNUAL REPORTS (placeholder)
       ==================================================== -->
  <section class="bg-white" aria-labelledby="docs-heading">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 id="docs-heading" class="text-2xl sm:text-3xl font-bold text-dacsa-dark mb-4">
        Documentación
      </h2>
      <p class="text-sm text-dacsa-gray mb-8">
        Memorias de actividades e informes oficiales publicados por la Cátedra DACSA-UV.
      </p>

      <!-- TODO: Replace these placeholder entries with links to real PDF documents when available -->
      <ul class="divide-y divide-gray-100 border border-gray-100 rounded-sm list-none" role="list">

        <li class="flex items-center justify-between gap-4 px-5 py-4">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 flex items-center justify-center bg-gray-100 rounded-sm shrink-0" aria-hidden="true">
              <svg class="w-4 h-4 text-dacsa-gray" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-dacsa-dark">Memoria de actividades 2023–2024</p>
              <p class="text-xs text-dacsa-gray">PDF — próximamente disponible</p>
            </div>
          </div>
          <span class="text-xs font-medium text-dacsa-gray bg-gray-100 px-2.5 py-1 rounded-full whitespace-nowrap">
            Próximamente
          </span>
        </li>

        <li class="flex items-center justify-between gap-4 px-5 py-4">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 flex items-center justify-center bg-gray-100 rounded-sm shrink-0" aria-hidden="true">
              <svg class="w-4 h-4 text-dacsa-gray" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-dacsa-dark">Convocatoria Premio Plan de Viabilidad 2024 (DOGV)</p>
              <p class="text-xs text-dacsa-gray">PDF — próximamente disponible</p>
            </div>
          </div>
          <span class="text-xs font-medium text-dacsa-gray bg-gray-100 px-2.5 py-1 rounded-full whitespace-nowrap">
            Próximamente
          </span>
        </li>

      </ul>
    </div>
  </section>

</BaseLayout>
