---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  lang="en"
  description="Chair of Excellence and Development in Entrepreneurship: from Student to Entrepreneur — Universitat de Valencia"
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold text-dacsa-dark mb-6">
      From <span class="text-dacsa-amber">Student</span> to <span class="text-dacsa-green"
        >Entrepreneur</span
      >
    </h1>
    <p class="text-xl text-dacsa-gray max-w-2xl mx-auto">
      The DACSA-UV Chair promotes university entrepreneurship in the Valencian Community since 2013.
    </p>
  </section>
</BaseLayout>
